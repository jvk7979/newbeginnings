rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Normalize the auth email so casing variants can't bypass the
    // allowlist (`Foo@Gmail.com` → `foo@gmail.com`). Also require
    // email_verified so an unverified federated identity can't squat
    // on an admin address.
    function userEmail() {
      return request.auth.token.email.lower();
    }
    function isVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    function isAdmin() {
      return isVerified()
          && (userEmail() == 'thenewbeginningsventure@gmail.com'
           || userEmail() == 'nsivasree99@gmail.com');
    }
    function isAllowed() {
      return isVerified()
          && (isAdmin() || exists(/databases/$(database)/documents/allowedUsers/$(userEmail())));
    }
    // Editor gate — strictly stronger than isAllowed(). A user is an editor
    // iff they're an admin OR they're on the allowlist AND their roster doc
    // does NOT carry role == 'Viewer'. Without this, a Viewer-invited user
    // could open DevTools and call setDoc()/deleteDoc() on any shared doc
    // because the client's read-only chrome was the only thing stopping
    // them — server-side, read and write shared a single allow rule.
    // Treating an absent `role` field as editor preserves backward
    // compatibility with allowedUsers docs created before the role field
    // existed (the AccessPage UI introduces a Viewer/Editor toggle that
    // populates the field going forward).
    function isEditor() {
      return isVerified()
          && (isAdmin()
              || (exists(/databases/$(database)/documents/allowedUsers/$(userEmail()))
                  && get(/databases/$(database)/documents/allowedUsers/$(userEmail())).data.get('role', 'Editor') != 'Viewer'));
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId && isAllowed();
    }
    match /allowedUsers/{email} {
      // S4: admins can list/read the entire roster (the Access page).
      // Non-admins can read only their OWN doc — needed because the
      // client uses getDoc() in AuthContext to confirm the invite
      // (exists() works server-side from rules but isn't accessible
      // to client SDK read calls). Allowing self-read is safe: the
      // doc only contains email/name/addedAt/addedBy of the same
      // user, nothing else.
      allow read: if isVerified() && (isAdmin() || email == userEmail());
      allow write: if isAdmin();
    }
    // Shared collections: all allowed users READ; only editors (non-Viewer
    // roles) WRITE. Previously read/write shared a single rule, so a
    // Viewer-invited user could bypass the read-only client chrome and
    // call setDoc/deleteDoc directly via DevTools. The split below
    // enforces the role server-side.
    match /sharedIdeas/{doc} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    match /sharedProjects/{doc} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    match /sharedPlans/{doc} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    match /sharedCommodities/{doc} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    // Supplier / vendor directory — name, materials, contacts, quoted
    // price, and the projectIds they're linked to. Same family-shared
    // access model as the other shared collections.
    match /sharedSuppliers/{doc} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    // Markets auto-fetch settings (marketsConfig/autoFetch) — pause flag,
    // frequency, time-of-day. Any allowed user can READ it; only editors
    // can change it. The scheduled Cloud Function reads/writes via the
    // Admin SDK, which bypasses rules.
    match /marketsConfig/{doc} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    match /ideaDiscussions/{ideaId}/{document=**} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    match /planDiscussions/{planId}/{document=**} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    // Per-project Research Vault clips — web links, PDFs, quotes, photos
    // collected against a plan. Mirrors the access model of the parent
    // sharedPlans collection: any signed-in allowed family member reads,
    // only editors mutate.
    match /sharedPlans/{planId}/clips/{clipId} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    // Per-plan calculation scenarios — frozen calc-input snapshots saved
    // from the Calculations page. Same access model as clips: any allowed
    // family member reads, only editors mutate.
    match /sharedPlans/{planId}/scenarios/{scenarioId} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    // Activity feed — lightweight "who did what" events (created / deleted /
    // status changed) shown on the Dashboard. Created by editors as a side
    // effect of their writes; never updated or deleted from the client.
    match /sharedActivity/{eventId} {
      allow read:   if request.auth != null && isAllowed();
      allow create: if request.auth != null && isEditor();
      allow update, delete: if false;
    }
    // Step 3: per-idea topic threads. ideaTopics holds the topic metadata
    // (title, category, author); ideaTopicComments holds each topic's
    // comment thread (mirrors the existing ideaDiscussions / planDiscussions
    // structure so the DiscussionThread component can be reused unchanged).
    match /ideaTopics/{ideaId}/{document=**} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    match /ideaTopicComments/{topicId}/{document=**} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if request.auth != null && isEditor();
    }
    // Per-user cooldown / quota docs. Written exclusively by Cloud
    // Functions via the Admin SDK (which bypasses rules), so no
    // client write path. Users can read their own quota docs for
    // diagnostic display, but never another user's. Doc IDs are
    // `${uid}__${endpoint}` so the prefix match works.
    match /userQuota/{docId} {
      allow read:  if request.auth != null && docId.matches(request.auth.uid + '__.*');
      allow write: if false;
    }
    // World Market export data — seeded/synced by Cloud Functions (Admin SDK,
    // bypasses rules). Any allowed signed-in user can read. No client writes.
    match /worldMarketExports/{docId} {
      allow read:  if request.auth != null && isAllowed();
      allow write: if false;
    }
  }
}
