rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Normalize the auth email so casing variants can't bypass the
    // allowlist (`Foo@Gmail.com` → `foo@gmail.com`). Also require
    // email_verified so an unverified federated identity can't squat
    // on an admin address.
    function userEmail() {
      return request.auth.token.email.lower();
    }
    function isVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    function isAdmin() {
      return isVerified()
          && (userEmail() == 'thenewbeginningsventure@gmail.com'
           || userEmail() == 'nsivasree99@gmail.com');
    }
    function isAllowed() {
      return isVerified()
          && (isAdmin() || exists(/databases/$(database)/documents/allowedUsers/$(userEmail())));
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId && isAllowed();
    }
    match /allowedUsers/{email} {
      // S4: only admins can list/read the invite roster. Per-doc exists()
      // checks used by isAllowed() do NOT require list permission and
      // continue to work for every signed-in user.
      allow read: if request.auth != null && isAdmin();
      allow write: if isAdmin();
    }
    match /sharedIdeas/{doc} {
      allow read, write: if request.auth != null && isAllowed();
    }
    match /sharedProjects/{doc} {
      allow read, write: if request.auth != null && isAllowed();
    }
    match /sharedPlans/{doc} {
      allow read, write: if request.auth != null && isAllowed();
    }
    match /sharedFiles/{fileId} {
      allow read, write: if request.auth != null && isAllowed();
    }
    match /ideaDiscussions/{ideaId}/{document=**} {
      allow read, write: if request.auth != null && isAllowed();
    }
    match /planDiscussions/{planId}/{document=**} {
      allow read, write: if request.auth != null && isAllowed();
    }
  }
}
