rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Parity with firestore.rules — same normalization (lowercase email)
    // and same email_verified gate. Without this, Storage and Firestore
    // disagree about who's allowed: a token whose email matches the
    // Firestore-side normalized comparison can fail the Storage-side raw
    // comparison, surfacing as "User does not have permission to access"
    // even when the Firestore allowedUsers doc clearly exists.
    function userEmail() {
      return request.auth.token.email.lower();
    }
    function isVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    function isAdmin() {
      return isVerified()
          && (userEmail() == 'thenewbeginningsventure@gmail.com'
              || userEmail() == 'nsivasree99@gmail.com');
    }
    function isAllowed() {
      return isVerified()
          && (isAdmin()
              || firestore.exists(
                   /databases/(default)/documents/allowedUsers/$(userEmail())
                 ));
    }

    match /uploads/{blobId} {
      allow read: if isAllowed();
      allow create, update: if isAllowed()
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType in [
             'application/pdf',
             'application/msword',
             'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
           ];
      allow delete: if isAllowed();
    }
  }
}
